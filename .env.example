# ──────────────────────────────────────────────────────────────────────────
# ICP Agent Platform – Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
# SECRET_KEY=your-super-secret-key-change-in-production

# ── Database (required) ─────────────────────────────────────────────────
# For local Docker Compose setup:
DATABASE_URL=postgresql://agent:agent@localhost:5432/agentic

# ── LLM Provider (required) ─────────────────────────────────────────────
# Supported: gemini, openai, groq
LLM_PROVIDER=gemini
LLM_MODEL=Gemini-2.5-Flash-Lite
LLM_API_KEY=your-primary-llm-api-key

# Optional rotation / fallback LLM API keys
# LLM_API_KEY_2=your-secondary-api-key-2
# LLM_API_KEY_3=your-secondary-api-key-3
# LLM_API_KEY_4=your-secondary-api-key-4
# LLM_API_KEY_5=your-secondary-api-key-5

# ── Groq Specific / Fast Routing ─────────────────────────────────────────
# Comma-separated list of Groq API keys and models
# GROQ_API_KEYS=gsk_key1,gsk_key2
# GROQ_MODELS=llama-3.3-70b-versatile

# ── Integration & Tool API Keys ──────────────────────────────────────────
NEWS_API_KEY=your-news-api-key
GITHUB_TOKEN=your-github-token
APIFY_API_TOKEN=your-apify-api-token
TAVILY_API_KEY=your-tavily-api-key
# SCRAPER_API_KEY=your-scraper-api-key
# ENRICHMENT_API_KEY=your-enrichment-api-key

# ── Operational Tunables ─────────────────────────────────────────────────
# MAX_RETRIES=3
# HITL_TIMEOUT_SECONDS=86400
